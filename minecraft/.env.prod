DRIVER=~fastapi+~httpx+~websockets

HOST=127.0.0.1
PORT=8083

ONEBOT_WS_URL=ws://localhost:3002/onebot/v11/ws

# nonebot_plugin_mcqq 配置
mc_qq__enable=true
mc_qq__debug=false
mc_qq__server_name="依依家的方块人"
mc_qq__access_token="15303480281"
mc_qq__message_prefix="[鹊桥]"

# WebSocket Client 配置（连接到服务器）
mc_qq__websocket_client__enable=true
mc_qq__websocket_client__reconnect_interval=5
mc_qq__websocket_client__reconnect_max_times=5
mc_qq__websocket_client__url_list=["ws://zz3.shiyuegame.cloud:20177"]

# WebSocket Server 配置（接收服务器连接）
mc_qq__websocket_server__enable=false

# Rcon 配置
mc_qq__rcon__enable=false

# 订阅事件配置
mc_qq__subscribe_event__player_chat=true
mc_qq__subscribe_event__player_death=true
mc_qq__subscribe_event__player_join=true
mc_qq__subscribe_event__player_quit=true
mc_qq__subscribe_event__player_command=true
mc_qq__subscribe_event__player_advancement=true

# 忽略的命令列表
mc_qq__ignored_commands=[]

# 服务器群组配置
mc_qq__server_dict={"依依家的方块人": {"group_list": [{"group_id": "908188794", "adapter": "onebot", "bot_id": "826322248"}], "rcon_msg": false}}